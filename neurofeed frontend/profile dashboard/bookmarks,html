<script>
        function switchTab(tab) {
            // Content divs
            const reels = document.getElementById('content-reels');
            const docs = document.getElementById('content-docs');
            const paths = document.getElementById('content-paths');
            
            // Buttons
            const btnReels = document.getElementById('tab-reels');
            const btnDocs = document.getElementById('tab-docs');
            const btnPaths = document.getElementById('tab-paths');

            // Reset all
            reels.classList.add('hidden');
            reels.classList.remove('grid');
            docs.classList.add('hidden');
            docs.classList.remove('grid');
            paths.classList.add('hidden');
            paths.classList.remove('grid');

            btnReels.classList.remove('border-primary', 'text-primary', 'font-bold');
            btnReels.classList.add('border-transparent', 'text-on-surface-variant');
            btnDocs.classList.remove('border-primary', 'text-primary', 'font-bold');
            btnDocs.classList.add('border-transparent', 'text-on-surface-variant');
            btnPaths.classList.remove('border-primary', 'text-primary', 'font-bold');
            btnPaths.classList.add('border-transparent', 'text-on-surface-variant');

            // Activate specific
            if (tab === 'reels') {
                reels.classList.remove('hidden');
                reels.classList.add('grid');
                btnReels.classList.add('border-primary', 'text-primary', 'font-bold');
                btnReels.classList.remove('border-transparent', 'text-on-surface-variant');
            } else if (tab === 'docs') {
                docs.classList.remove('hidden');
                docs.classList.add('grid');
                btnDocs.classList.add('border-primary', 'text-primary', 'font-bold');
                btnDocs.classList.remove('border-transparent', 'text-on-surface-variant');
            } else if (tab === 'paths') {
                paths.classList.remove('hidden');
                paths.classList.add('grid');
                btnPaths.classList.add('border-primary', 'text-primary', 'font-bold');
                btnPaths.classList.remove('border-transparent', 'text-on-surface-variant');
            }
        }

        // Add micro-interaction for bookmark buttons
        document.querySelectorAll('button[title="Unbookmark"]').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const icon = this.querySelector('.material-symbols-outlined');
                if (icon.classList.contains('fill-icon')) {
                    icon.classList.remove('fill-icon');
                    icon.style.fontVariationSettings = "'FILL' 0";
                    this.parentElement.parentElement.classList.add('opacity-40', 'grayscale');
                    setTimeout(() => {
                         // In a real app, this would remove the element or update DB
                         console.log("Unbookmarked item");
                    }, 300);
                } else {
                    icon.classList.add('fill-icon');
                    icon.style.fontVariationSettings = "'FILL' 1";
                    this.parentElement.parentElement.classList.remove('opacity-40', 'grayscale');
                }
            });
        });
    </script>
